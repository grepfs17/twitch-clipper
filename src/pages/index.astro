---
import Layout from "../layouts/Layout.astro";
import "../styles/index.css";
---

<Layout title="Twitch Clip Explorer">
    <main>
        <header class="hero">
            <div class="container">
                <div class="hero-inner">
                    <p class="hero-status">
                        twitch_clip_explorer --interactive
                    </p>
                    <h1 class="font-display">
                        Twitch Clip Explorer<span class="cursor"></span>
                    </h1>

                    <div class="search-wrapper">
                        <p class="search-prompt-line">
                            enter channel name to begin
                        </p>
                        <div class="search-box">
                            <span class="search-prompt">$_</span>
                            <input
                                type="text"
                                id="channelInput"
                                placeholder="channel (e.g. lunateac)"
                                spellcheck="false"
                                autocomplete="off"
                            />
                            <button id="searchBtn" class="btn-primary"
                                >SCAN</button
                            >
                        </div>
                        <div id="recentSearches" class="recent-searches hidden">
                            <span class="recent-label">recent</span>
                            <ul id="recentList" class="recent-list"></ul>
                        </div>
                    </div>
                </div>
            </div>
        </header>

        <section id="resultsSection" class="results-section hidden">
            <div class="container">
                <div class="toolbar">
                    <div class="filters-group">
                        <div class="filter-item">
                            <label>Popularity</label>
                            <div class="custom-select">
                                <button
                                    type="button"
                                    class="custom-select-trigger"
                                    id="rangeFilterTrigger">All Time</button
                                >
                                <input
                                    type="hidden"
                                    id="rangeFilter"
                                    value="all"
                                />
                                <ul
                                    class="custom-select-options"
                                    id="rangeFilterOptions"
                                >
                                    <li data-value="all">All Time</li>
                                    <li data-value="24h">Last 24 Hours</li>
                                    <li data-value="7d">Last 7 Days</li>
                                    <li data-value="30d">Last 30 Days</li>
                                </ul>
                            </div>
                        </div>

                        <div class="filter-item">
                            <label>Category</label>
                            <div class="autocomplete-wrapper">
                                <input
                                    type="text"
                                    id="categoryInput"
                                    placeholder="All Categories"
                                    autocomplete="off"
                                />
                                <button
                                    type="button"
                                    id="categoryClear"
                                    class="autocomplete-clear hidden"
                                    aria-label="Clear category">&times;</button
                                >
                                <input
                                    type="hidden"
                                    id="categoryFilter"
                                    value="all"
                                />
                                <ul id="categoryList" class="autocomplete-list">
                                </ul>
                            </div>
                        </div>

                        <div class="filter-item">
                            <label>Sort By</label>
                            <div class="custom-select">
                                <button
                                    type="button"
                                    class="custom-select-trigger"
                                    id="sortFilterTrigger">Most Views</button
                                >
                                <input
                                    type="hidden"
                                    id="sortFilter"
                                    value="views"
                                />
                                <ul
                                    class="custom-select-options"
                                    id="sortFilterOptions"
                                >
                                    <li data-value="views">Most Views</li>
                                    <li data-value="latest">Latest</li>
                                    <li data-value="oldest">Oldest</li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <div class="toolbar-right">
                        <div id="cacheIndicator" class="cache-indicator hidden">
                            <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
                            <span id="cacheText" class="cache-text"></span>
                            <button type="button" id="cacheRefresh" class="cache-refresh-btn">Refresh</button>
                        </div>
                        <div class="stats">
                            <span id="clipsCount">0</span> clips found
                            <button
                                type="button"
                                id="loadOlderBtn"
                                class="load-older-btn hidden">Load all clips</button
                            >
                        </div>
                    </div>
                </div>

                <div id="clipsGrid" class="clips-grid">
                    <!-- Clips will be injected here -->
                </div>

                <div id="loader" class="loader hidden">
                    <div class="spinner"></div>
                    <span id="loaderText" class="loader-text"></span>
                </div>
                <div id="progressArea" class="progress-area hidden">
                    <div class="progress-bar-track">
                        <div
                            id="progressBar"
                            class="progress-bar-fill"
                            style="width: 0%"
                        >
                        </div>
                    </div>
                    <div class="progress-info">
                        <span id="progressLabel" class="progress-label"></span>
                        <span id="progressStats" class="progress-stats"></span>
                    </div>
                </div>

                <div id="emptyState" class="empty-state hidden">
                    <p>No clips found for this criteria.</p>
                </div>
            </div>
        </section>

        <footer class="footer">
            <div class="container">
                <p>© 2024 Twitch Clip Explorer • Built with Astro</p>
            </div>
        </footer>
    </main>

    <div id="clipModal" class="modal-overlay hidden">
        <div class="modal-content">
            <button
                type="button"
                id="modalCloseBtn"
                class="modal-close"
                aria-label="Close">&times;</button
            >
            <div class="modal-video-wrapper">
                <iframe id="modalIframe" src="" frameborder="0" allowfullscreen
                ></iframe>
            </div>
            <div class="modal-body">
                <h2 id="modalTitle" class="modal-title"></h2>
                <div class="modal-meta">
                    <span id="modalGame" class="modal-game"></span>
                    <span class="meta-dot"></span>
                    <span id="modalDate" class="modal-date"></span>
                </div>
                <div class="modal-actions">
                    <div class="download-quality-group">
                        <label for="qualitySelect" class="quality-label"
                            >Download Quality</label
                        >
                        <div class="custom-select">
                            <button
                                type="button"
                                class="custom-select-trigger"
                                id="qualitySelectTrigger">Best Quality</button
                            >
                            <input
                                type="hidden"
                                id="qualitySelect"
                                value="best"
                            />
                            <ul
                                class="custom-select-options"
                                id="qualitySelectOptions"
                            >
                                <li data-value="best">Best Quality</li>
                                <li data-value="1080p">1080p</li>
                                <li data-value="720p">720p</li>
                                <li data-value="480p">480p</li>
                                <li data-value="360p">360p</li>
                                <li data-value="160p">160p</li>
                                <li class="optgroup-header">Portrait Mode</li>
                                <li data-value="portrait-1080p">
                                    1080p Portrait
                                </li>
                                <li data-value="portrait-720p">
                                    720p Portrait
                                </li>
                                <li data-value="portrait-480p">
                                    480p Portrait
                                </li>
                                <li data-value="portrait-360p">
                                    360p Portrait
                                </li>
                                <li data-value="portrait-160p">
                                    160p Portrait
                                </li>
                            </ul>
                        </div>
                    </div>
                    <div class="modal-btn-group">
                        <button
                            type="button"
                            id="modalDownloadBtn"
                            class="btn-primary download-btn"
                        >
                            <svg
                                viewBox="0 0 24 24"
                                width="16"
                                height="16"
                                fill="currentColor"
                                ><path
                                    d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"
                                ></path></svg
                            >
                            Download
                        </button>
                        <div
                            class="download-progress"
                            id="downloadProgress"
                            style="display:none"
                        >
                            <div class="download-progress-bar">
                                <div
                                    class="download-progress-fill"
                                    id="downloadProgressFill"
                                >
                                </div>
                            </div>
                            <span
                                class="download-progress-text"
                                id="downloadProgressText">0%</span
                            >
                        </div>
                        <button
                            type="button"
                            id="modalCopyBtn"
                            class="btn-primary copy-btn"
                        >
                            <svg
                                viewBox="0 0 24 24"
                                width="16"
                                height="16"
                                fill="currentColor"
                                ><path
                                    d="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z"
                                ></path></svg
                            >
                            Copy Link
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</Layout>

<script>
    import "../scripts/index";
</script>
